// Array demo: declare, initialize, index, and print array elements
function main() {
    let arr[5] = {10, 20, 30, 40, 50};
    let i = 0;
    while (i < len(arr)) {
        print(arr[i] + 48);
        i = i + 1;
    }
    print(10);
    arr[0] = 99;
    print(arr[0] + 48);
    print(10);
    halt;
}
